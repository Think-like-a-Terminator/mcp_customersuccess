# Authentication Settings
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# PostgreSQL Database Configuration
# For Cloud Run: use Unix socket path
# For local with Cloud SQL Proxy: use localhost
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=customer_success
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password

OAUTH_PUBLIC_BASE_URL=http://localhost:8000

# Server Settings
SERVER_NAME=customer-success-mcp
SERVER_VERSION=0.1.0

# ── Slack Notifications (optional) ──────────────────────────────────────────
# Create a Slack app at https://api.slack.com/apps → Add Incoming Webhook
# When set, high/medium risk alerts are automatically posted to your channel.
SLACK_WEBHOOK_URL=

# ── Salesforce CRM Integration (optional) ───────────────────────────────────
# Required package: pip install simple-salesforce
# Use sync_from_crm(crm="salesforce") MCP tool to pull accounts.
# Set SALESFORCE_DOMAIN=test for sandboxes.
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=
SALESFORCE_DOMAIN=login

# ── HubSpot CRM Integration (optional) ──────────────────────────────────────
# Required package: pip install hubspot-api-client
# Create a Private App at https://app.hubspot.com/api-keys and grant CRM read scope.
# Use sync_from_crm(crm="hubspot") MCP tool to pull companies.
HUBSPOT_API_KEY=
